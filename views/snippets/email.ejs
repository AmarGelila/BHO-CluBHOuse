<div
  style="
    font-family: &quot;Helvetica Neue&quot;, Helvetica, Arial, sans-serif;
    max-width: 600px;
    margin: auto;
    padding: 20px;
    border: 1px solid #eee;
    border-radius: 10px;
  "
>
  <h2 style="color: #2d3436; text-align: center">
    Welcome to the Club, <%= fullname %>!
  </h2>
  <p style="font-size: 16px; color: #636e72">
    You're just one step away from your BHO Clubhouse Private Membership. Use
    the code below to verify your account.
  </p>
  <div
    style="
      background-color: #f9fafb;
      padding: 20px;
      text-align: center;
      border-radius: 8px;
      margin: 30px 0;
    "
  >
    <span
      style="
        font-size: 32px;
        font-weight: bold;
        letter-spacing: 10px;
        color: #0984e3;
      "
      ><%= code %></span
    >
  </div>
  <p style="font-size: 14px; color: #b2bec3; text-align: center">
    This code is time-sensitive. If you did not request this membership, please
    ignore this email.
  </p>
  <hr
    style="border: none; border-top: 1px solid #dfe6e9; margin: 40px 0 20px 0"
  />
  <p style="font-size: 12px; color: #636e72; text-align: center">
    <strong>BHO Clubhouse</strong>
  </p>
</div>
