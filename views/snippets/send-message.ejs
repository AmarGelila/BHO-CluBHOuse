<section id="send-message">
  <form action="/send-message" method="post">
    <div>

      <textarea
      name="message"
      id="message"
      placeholder="Write your message..."
      required
      ></textarea>
      <%- include("formError", {name: "message"}) %>
    </div>
    <button type="submit">Send</button>
  </form>
</section>
